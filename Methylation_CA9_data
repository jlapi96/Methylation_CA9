    "\n",
    "        feature = cols[2]\n",
    "        if feature not in (\"exon\", \"transcript\"):\n",
    "            continue\n",
    "\n",
    "        start, end, strand_col, attrs = int(cols[3]), int(cols[4]), cols[6], cols[8]\n",
    "\n",
    "        # Parse attributes\n",
