    "        if attr_dict.get(\"transcript_id\") != TARGET_TRANSCRIPT:\n",
    "            continue\n",
    "\n",
    "        if feature == \"exon\":\n",
    "            exons.append((start, end))\n",
    "        elif feature == \"transcript\":\n",
