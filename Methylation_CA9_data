    "\n",
    "exons = sorted(exons)\n",
    "promoter_start = tss - PROMOTER_UPSTREAM if strand == \"+\" else tss\n",
    "promoter_end   = tss if strand == \"+\" else tss + PROMOTER_UPSTREAM\n",
    "\n",
    "print(f\"{GENE_NAME} | Strand: {strand} | TSS: {tss} | Exons: {len(exons)}\")\n",
    "\n",
